<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5F7"
    tools:context=".KelolaMahasiswaActivity">

    <!-- ================= TOPBAR ================= -->

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kelola Mahasiswa"
                android:textColor="#2B1D24"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Tambah, edit, dan hapus mahasiswa"
                android:textColor="#9A8E95"
                android:textSize="12sp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ================= CONTENT ================= -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ================= STATS ================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#B1456E"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="22dp">

                    <!-- ICON -->

                    <LinearLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="#1FFFFFFF"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎓"
                            android:textSize="26sp"/>

                    </LinearLayout>

                    <!-- INFO -->

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Mahasiswa"
                            android:textColor="#FCE4EC"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/tvTotalMahasiswa"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="120"
                            android:textColor="@android:color/white"
                            android:textSize="30sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                    <!-- BUTTON -->

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTambahMahasiswa"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="+ Tambah"
                        android:textAllCaps="false"
                        android:textColor="#B1456E"
                        android:textStyle="bold"
                        app:backgroundTint="@android:color/white"
                        app:cornerRadius="14dp"/>



                </LinearLayout>


            </com.google.android.material.card.MaterialCardView>


            <!-- ================= SEARCH ================= -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnImportExcel"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:text="Import Excel"
                android:textAllCaps="false"
                android:textColor="#ffff"
                android:textStyle="bold"
                app:backgroundTint="#7B61FF"
                app:cornerRadius="14dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#EFE5EA"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_search"
                        android:tint="#999999"/>

                    <EditText
                        android:id="@+id/etSearchMahasiswa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@android:color/transparent"
                        android:hint="Cari mahasiswa..."
                        android:textColor="#2B1D24"
                        android:textColorHint="#B0A4AA"
                        android:textSize="14sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ================= TITLE ================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Daftar Mahasiswa"
                android:textColor="#2B1D24"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- ================= RECYCLER ================= -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerMahasiswa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ================= BOTTOM NAVBAR ================= -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavbar"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        android:backgroundTint="#FFFFFF"
        app:cardCornerRadius="44dp"
        app:cardElevation="2dp"
        app:strokeColor="#F1DCE5"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <!-- ================= RUMAH ================= -->

            <LinearLayout
                android:id="@+id/navRumah"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_compass"
                    android:tint="#9E9E9E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Home"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- ================= USER ================= -->

            <LinearLayout
                android:id="@+id/navUser"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_manage"
                    android:tint="#9E9E9E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="User"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- ================= MAHASISWA ================= -->

            <LinearLayout
                android:id="@+id/navMahasiswa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <LinearLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:background="@drawable/nav_active_bg">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:tint="@android:color/white"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Mahasiswa"
                    android:textColor="#B1456E"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- ================= KOMPENSASI ================= -->

            <LinearLayout
                android:id="@+id/navKompensasi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:tint="#9E9E9E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Kompensasi"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- ================= LOGOUT ================= -->

            <LinearLayout
                android:id="@+id/navLogout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    android:tint="#E57373"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Logout"
                    android:textColor="#E57373"
                    android:textSize="11sp"/>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>