<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6EEF2"
    tools:context=".KelolaKompensasiActivity">

    <!-- ================= CONTENT ================= -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ================= HEADER ================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#B1456E"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="50dp"
                android:paddingEnd="24dp"
                android:paddingBottom="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data Kompensasi"
                    android:textColor="@android:color/white"
                    android:textSize="30sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Kelola data kompensasi mahasiswa"
                    android:textColor="#FCE4EC"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- ================= MAIN ================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- ================= TOTAL ================= -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#B1456E"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="22dp">

                        <LinearLayout
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:background="#1FFFFFFF"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📚"
                                android:textSize="28sp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Kompensasi"
                                android:textColor="#FCE4EC"
                                android:textSize="13sp"/>

                            <TextView
                                android:id="@+id/tvTotalKompensasi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@android:color/white"
                                android:textSize="30sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTambahKompensasi"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="+ Tambah"
                            android:textAllCaps="false"
                            android:textColor="#B1456E"
                            android:textStyle="bold"
                            app:backgroundTint="@android:color/white"
                            app:cornerRadius="14dp"/>

                    </LinearLayout>


                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnImportExcelKompensasi"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:text="Import Excel"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#7B61FF"
                    app:cornerRadius="14dp"/>
                <!-- ================= SEARCH ================= -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:strokeColor="#EFE5EA"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:tint="#999999"/>

                        <EditText
                            android:id="@+id/etSearchKompensasi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@android:color/transparent"
                            android:hint="Cari kompensasi"
                            android:textColor="#2B1D24"
                            android:textColorHint="#B0A4AA"
                            android:textSize="14sp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ================= FILTER ================= -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none">

                    <RadioGroup
                        android:id="@+id/rgFilterKompensasi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rbSemua"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Semua"
                            android:checked="true"
                            android:background="@drawable/filter_bg_selector"
                            android:button="@null"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:textColor="@color/filter_text_selector"
                            android:layout_marginEnd="8dp"/>

                        <RadioButton
                            android:id="@+id/rbSelesai"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selesai"
                            android:background="@drawable/filter_bg_selector"
                            android:button="@null"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:textColor="@color/filter_text_selector"
                            android:layout_marginEnd="8dp"/>

                        <RadioButton
                            android:id="@+id/rbBelumKompen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Belum Kompen"
                            android:background="@drawable/filter_bg_selector"
                            android:button="@null"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:textColor="@color/filter_text_selector"
                            android:layout_marginEnd="8dp"/>

                        <RadioButton
                            android:id="@+id/rbPending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending"
                            android:background="@drawable/filter_bg_selector"
                            android:button="@null"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:textColor="@color/filter_text_selector"/>

                    </RadioGroup>
                </HorizontalScrollView>

                <!-- ================= TITLE ================= -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Daftar Kompensasi"
                    android:textColor="#2B1D24"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <!-- ================= RECYCLER ================= -->

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerKompensasi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_kompensasi"/>

                <!-- ================= PAGINATION ================= -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPrevPage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&lt;"
                        android:layout_marginEnd="16dp"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#B1456E"/>

                    <TextView
                        android:id="@+id/tvPageInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Halaman 1"
                        android:textColor="#2B1D24"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNextPage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&gt;"
                        android:layout_marginStart="16dp"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#B1456E"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ================= BOTTOM NAVBAR ================= -->

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        android:backgroundTint="#FFFFFF"
        app:cardCornerRadius="44dp"
        app:cardElevation="2dp"
        app:strokeColor="#F1DCE5"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <!-- HOME -->

            <LinearLayout
                android:id="@+id/navRumah"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_compass"
                    android:tint="#9E9E9E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- USER -->

            <LinearLayout
                android:id="@+id/navUser"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_manage"
                    android:tint="#9E9E9E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- MAHASISWA -->

            <LinearLayout
                android:id="@+id/navMahasiswa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:tint="#9E9E9E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mahasiswa"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- ACTIVE -->

            <LinearLayout
                android:id="@+id/navKompensasi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:background="@drawable/nav_active_bg">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        android:tint="@android:color/white"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Kompensasi"
                    android:textColor="#B1456E"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- LOGOUT -->

            <LinearLayout
                android:id="@+id/navLogout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    android:tint="#E57373"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Logout"
                    android:textColor="#E57373"
                    android:textSize="11sp"/>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>