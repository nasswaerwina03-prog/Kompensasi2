<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:backgroundTint="#FFFFFF"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- HEADER ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTugas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#3A2A33"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- JAM & MENIT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvJam"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawablePadding="4dp"
                android:textColor="#777"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvMenit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#F3D6E1"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:textColor="#B1456E"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- TANGGAL -->
        <TextView
            android:id="@+id/tvTanggal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#AAAAAA"
            android:textSize="12sp"/>

        <!-- ALASAN (hidden by default) -->
        <TextView
            android:id="@+id/tvAlasan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#FFF3F5"
            android:padding="8dp"
            android:textColor="#E53935"
            android:textSize="12sp"
            android:visibility="gone"/>

        <!-- ACTIONS -->
        <LinearLayout
            android:id="@+id/layoutAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApproveSesi"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="Approve"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:backgroundTint="#4CAF50"
                app:cornerRadius="18dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTolakSesi"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="Tolak"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:backgroundTint="#E53935"
                app:cornerRadius="18dp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLihatBukti"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="6dp"
            android:text="Lihat Bukti / Video"
            android:textColor="#3A2A33"
            android:textSize="12sp"
            android:visibility="gone"
            app:backgroundTint="#F1DCE5"
            app:cornerRadius="18dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
