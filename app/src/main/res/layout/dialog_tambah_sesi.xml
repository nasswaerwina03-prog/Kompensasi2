<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvSisaInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="#FFF3F5"
        android:padding="10dp"
        android:textColor="#B1456E"
        android:textSize="13sp"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama Tugas"
        android:textColor="#555"
        android:textSize="12sp"/>

    <EditText
        android:id="@+id/etTugas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Contoh: Piket Laboratorium"
        android:inputType="text"
        android:textSize="14sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Jam Mulai"
        android:textColor="#555"
        android:textSize="12sp"/>

    <EditText
        android:id="@+id/etJamMulai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:focusable="false"
        android:hint="Ketuk untuk pilih waktu"
        android:textSize="14sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Jam Selesai"
        android:textColor="#555"
        android:textSize="12sp"/>

    <EditText
        android:id="@+id/etJamSelesai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:focusable="false"
        android:hint="Ketuk untuk pilih waktu"
        android:textSize="14sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Jumlah Menit (maks 360)"
        android:textColor="#555"
        android:textSize="12sp"/>

    <EditText
        android:id="@+id/etMenit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Contoh: 180"
        android:inputType="number"
        android:textSize="14sp"/>

</LinearLayout>
