<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6EEF2"
    tools:context=".DashboardAdminActivity">

    <!-- ================= FLOATING PROFILE ONLY ================= -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topUserNavbar"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="20dp"
        android:backgroundTint="#FFFFFF"
        app:cardCornerRadius="30dp"
        app:cardElevation="2dp"
        app:strokeColor="#F1DCE5"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <!-- PROFILE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:backgroundTint="#FCE4EC"
                app:cardCornerRadius="21dp"
                app:cardElevation="0dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_person"
                    app:civ_border_width="1dp"
                    app:civ_border_color="#B1456E"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- INFO -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin"
                    android:textColor="#3A2A33"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Administrator"
                    android:textColor="#999999"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- LOGOUT REMOVED FROM HERE -->

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ================= CONTENT ================= -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ================= HEADER ================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#B1456E"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="100dp"
                android:paddingEnd="24dp"
                android:paddingBottom="30dp">

                <!-- TITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dashboard Admin"
                    android:textColor="@android:color/white"
                    android:textSize="30sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Sistem Kompensasi Mahasiswa"
                    android:textColor="#FCE4EC"
                    android:textSize="14sp"/>

                <!-- WELCOME -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="#26FFFFFF"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#33FFFFFF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selamat Datang 👋"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Kelola seluruh kompensasi mahasiswa secara modern dan efisien."
                            android:textColor="#FCE4EC"
                            android:textSize="13sp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ================= MAIN CONTENT ================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- ================= STATISTICS ================= -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- MAHASISWA -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#FFFFFF"
                        app:cardCornerRadius="30dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#F1DCE5"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:minHeight="145dp"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:gravity="center"
                                android:text="🎓"
                                android:textSize="30sp"
                                android:background="@drawable/icon_bg"/>

                            <TextView
                                android:id="@+id/tvTotalMahasiswa"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="120"
                                android:textColor="#B1456E"
                                android:textSize="32sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mahasiswa"
                                android:textColor="#777777"
                                android:textSize="13sp"/>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- KOMPENSASI -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#B1456E"
                        app:cardCornerRadius="30dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:minHeight="145dp"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:gravity="center"
                                android:text="📚"
                                android:textSize="30sp"
                                android:background="#26FFFFFF"/>

                            <TextView
                                android:id="@+id/tvTotalKompensasi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="45"
                                android:textColor="@android:color/white"
                                android:textSize="32sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kompensasi"
                                android:textColor="#FCE4EC"
                                android:textSize="13sp"/>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>


                <!-- ================= MENU ================= -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:text="Menu Utama"
                    android:textColor="#3A2A33"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:columnCount="2">

                    <!-- USER -->

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardUser"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:backgroundTint="#FFFFFF"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#F1DCE5"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:minHeight="170dp"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="70dp"
                                android:layout_height="70dp"
                                android:gravity="center"
                                android:text="👤"
                                android:textSize="34sp"
                                android:background="@drawable/icon_bg"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:text="User"
                                android:textColor="#3A2A33"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- MAHASISWA -->

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardMahasiswa"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:backgroundTint="#FFFFFF"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#F1DCE5"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:minHeight="170dp"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="70dp"
                                android:layout_height="70dp"
                                android:gravity="center"
                                android:text="🎓"
                                android:textSize="34sp"
                                android:background="@drawable/icon_bg"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:text="Mahasiswa"
                                android:textColor="#3A2A33"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- KOMPENSASI -->

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardKompensasi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:backgroundTint="#FFFFFF"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#F1DCE5"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:minHeight="170dp"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="70dp"
                                android:layout_height="70dp"
                                android:gravity="center"
                                android:text="📚"
                                android:textSize="34sp"
                                android:background="@drawable/icon_bg"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:text="Kompensasi"
                                android:textColor="#3A2A33"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </GridLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ================= BOTTOM NAVBAR ================= -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavbar"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        android:backgroundTint="#FFFFFF"
        app:cardCornerRadius="44dp"
        app:cardElevation="2dp"
        app:strokeColor="#F1DCE5"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <!-- ================= RUMAH ================= -->

            <LinearLayout
                android:id="@+id/navRumah"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <LinearLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:background="@drawable/nav_active_bg">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@android:color/white" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Home"
                    android:textColor="#B1456E"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- ================= USER ================= -->

            <LinearLayout
                android:id="@+id/navUser"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_manage"
                    android:tint="#9E9E9E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="User"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- ================= MAHASISWA ================= -->

            <LinearLayout
                android:id="@+id/navMahasiswa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:tint="#9E9E9E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Mahasiswa"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- ================= KOMPENSASI ================= -->

            <LinearLayout
                android:id="@+id/navKompensasi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:tint="#9E9E9E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Kompensasi"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- ================= LOGOUT ================= -->

            <LinearLayout
                android:id="@+id/navLogout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    android:tint="#E57373"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Logout"
                    android:textColor="#E57373"
                    android:textSize="11sp"/>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>